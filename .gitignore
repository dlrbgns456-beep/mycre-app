# ══════════════════════════════════════════════════════════
# 통합 .gitignore — 웹(www/) + 안드로이드 + iOS 단일 저장소
# ══════════════════════════════════════════════════════════

# ── Node / 빌드 ─────────────────────────────────
node_modules/
.netlify

# ── 안드로이드 ───────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/
android/.idea/
*.iml

# ── iOS ──────────────────────────────────────────
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/Podfile.lock

# ── 서명 키스토어 (절대 커밋 금지) ───────────────
*.keystore
*.jks

# ── OS / 에디터 ──────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
*.swp

# ── 로컬 자료 (PDF, 사진) ────────────────────────
*.pdf
크레 수컷/
크레 암컷/

# ── Claude Code 로컬 설정 ────────────────────────
.claude/

# === 로컬 전용 (2026-05-31 통합 추가) ===
docs/
business/
records/
_legacy/
keys/
_setup_unified.sh
CLAUDE.md.local_backup_*

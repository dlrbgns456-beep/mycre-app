{
  "appId": "com.lbeetle.byetmaru",
  "appName": "볏마루도감",
  "webDir": "www",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#FFF9EF",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#2E7D57"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "byetmaru.com",
      "*.byetmaru.com",
      "accounts.google.com",
      "*.google.com",
      "*.googleusercontent.com",
      "fatjjjwfauujgrvcihwd.supabase.co",
      "*.supabase.co",
      "kauth.kakao.com",
      "*.kakao.com",
      "appleid.apple.com",
      "*.apple.com"
    ]
  },
  "android": {
    "backgroundColor": "#FFF9EF",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "ios": {
    "backgroundColor": "#FFF9EF",
    "contentInset": "automatic",
    "scheme": "ByetMaru"
  }
}
